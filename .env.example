CLAUDE_MODEL=claude-sonnet-4-6
SPACY_MODEL=en_core_web_sm
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
MAX_PDF_SIZE_MB=10

ADZUNA_ID=
ADZUNA_API_KEY=
ADZUNA_COUNTRY=fr

JOOBLE_API_KEY=

